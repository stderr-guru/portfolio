---
interface Props {
  title?: string;
  activeNav?: 'work' | 'writing' | 'about' | 'playground' | 'contact';
}

const { title = 'Jordan Lowell', activeNav } = Astro.props;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,700;0,800;1,700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
  <script is:inline>
    const saved = localStorage.getItem('theme');
    const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
    if (saved === 'dark' || (!saved && prefersDark)) {
      document.documentElement.setAttribute('data-theme', 'dark');
    }
  </script>
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #EDEAE2;
      --purple: #7747CC;
      --black: #111111;
      --border: #D0CCC0;
      --text-body: #444444;
      --text-muted: #888888;
      --label-size: 0.7rem;
      --label-spacing: 0.12em;
    }

    [data-theme="dark"] {
      --bg: #161412;
      --purple: #9B71E8;
      --black: #EDEAE2;
      --border: #2C2925;
      --text-body: #d0ccc5;
      --text-muted: #a09c95;
    }

    body {
      background: var(--bg);
      color: var(--black);
      font-family: 'Inter', system-ui, sans-serif;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }

    nav {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0 2rem;
      height: 56px;
      border-bottom: 1px solid var(--border);
    }

    .logo {
      font-size: 0.8rem;
      font-weight: 500;
      letter-spacing: 0.1em;
      text-transform: uppercase;
      display: flex;
      align-items: center;
      gap: 0.4rem;
      text-decoration: none;
      color: var(--black);
    }

    .logo-dot {
      width: 8px;
      height: 8px;
      border-radius: 50%;
      background: var(--purple);
      display: inline-block;
      flex-shrink: 0;
    }

    .nav-links {
      display: flex;
      align-items: stretch;
      height: 100%;
      list-style: none;
      border-left: 1px solid var(--border);
    }

    .nav-links li {
      border-right: 1px solid var(--border);
    }

    .nav-links a {
      display: flex;
      align-items: center;
      padding: 0 1.5rem;
      height: 100%;
      font-size: var(--label-size);
      letter-spacing: var(--label-spacing);
      text-transform: uppercase;
      text-decoration: none;
      color: var(--black);
      font-weight: 500;
      white-space: nowrap;
    }

    .nav-links a:hover { opacity: 0.6; }

    .nav-links li.active a {
      background: var(--black);
      color: var(--bg);
    }

    .theme-toggle {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 40px;
      height: 100%;
      background: none;
      border: none;
      border-left: 1px solid var(--border);
      color: var(--black);
      cursor: pointer;
      transition: opacity 0.15s;
      flex-shrink: 0;
    }

    .theme-toggle:hover { opacity: 0.6; }

    .theme-toggle .icon-sun  { display: none; }
    .theme-toggle .icon-moon { display: block; }

    [data-theme="dark"] .theme-toggle .icon-sun  { display: block; }
    [data-theme="dark"] .theme-toggle .icon-moon { display: none; }

    main {
      flex: 1;
      display: flex;
      flex-direction: column;
    }

    footer {
      border-top: 1px solid var(--border);
    }

    .footer-main {
      padding: 0 2rem;
      height: 52px;
      display: flex;
      align-items: center;
      justify-content: space-between;
      border-bottom: 1px solid var(--border);
    }

    .footer-copy {
      font-size: var(--label-size);
      letter-spacing: var(--label-spacing);
      color: var(--text-muted);
    }

    .footer-icons {
      display: flex;
      align-items: center;
      gap: 1.25rem;
    }

    .footer-icons a {
      color: var(--text-muted);
      display: flex;
      align-items: center;
      text-decoration: none;
      transition: color 0.15s;
    }

    .footer-icons a:hover { color: var(--black); }

    .footer-tags {
      font-size: var(--label-size);
      letter-spacing: var(--label-spacing);
      color: var(--text-muted);
    }

    .footer-meta {
      padding: 0.6rem 2rem;
      display: flex;
      align-items: center;
      justify-content: space-between;
      gap: 2rem;
    }

    .footer-a11y,
    .footer-colophon {
      font-size: 0.65rem;
      letter-spacing: 0.04em;
      color: var(--text-muted);
      line-height: 1.5;
    }

    .footer-a11y a,
    .footer-colophon a {
      color: var(--text-muted);
      text-decoration: underline;
      text-underline-offset: 2px;
    }

    .footer-a11y a:hover,
    .footer-colophon a:hover { color: var(--black); }

    @media (max-width: 640px) {
      nav {
        flex-wrap: wrap;
        height: auto;
        padding: 0;
      }

      .logo {
        padding: 0 1rem;
        height: 48px;
        flex: 1;
      }

      .theme-toggle {
        height: 48px;
      }

      .nav-links {
        order: 1;
        width: 100%;
        border-left: none;
        border-top: 1px solid var(--border);
        height: 40px;
      }

      .nav-links li {
        flex: 1;
        border-right: none;
      }

      .nav-links li:not(:last-child) {
        border-right: 1px solid var(--border);
      }

      .nav-links a {
        padding: 0;
        justify-content: center;
        font-size: 0.65rem;
      }

      .footer-main {
        flex-direction: column;
        align-items: center;
        padding: 1rem;
        height: auto;
        gap: 0.75rem;
      }

      .footer-icons {
        order: -1;
      }

      .footer-meta {
        padding: 0.6rem 1rem;
        flex-direction: column;
        gap: 0.5rem;
      }
    }

  </style>
  <slot name="head" />
</head>
<body>

  <nav>
    <a href="/" class="logo">
      Jordan Lowell
      <span class="logo-dot"></span>
    </a>
    <ul class="nav-links">
      <li class={activeNav === 'work' ? 'active' : ''}><a href="/work">Work</a></li>
      <li class={activeNav === 'writing' ? 'active' : ''}><a href="/writing">Writing</a></li>
      <li class={activeNav === 'about' ? 'active' : ''}><a href="/about">About</a></li>
      <li class={activeNav === 'playground' ? 'active' : ''}><a href="/playground">Playground</a></li>
    </ul>
    <button class="theme-toggle" id="theme-toggle" aria-label="Toggle dark mode">
      <svg class="icon-moon" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
      <svg class="icon-sun" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
    </button>
  </nav>

  <script is:inline>
    const LIGHT_MODE_QUIPS = [
  'light mode? bold choice.',
  'hope you enjoy squinting.',
  'my eyes. my eyes.',
  'interesting. wrong, but interesting.',
  'some people just want to watch the world burn.',
  'this is not what the sun looks like either.',
  'sponsored by your local optometrist.',
  'ah, the crisp smell of burning retinas.',
  'who needs coffee when you have 100% brightness?',
  'is it legal to use this without sunglasses?',
  'welcome to the surface of the sun.',
  'flashbang, coming in!',
  'I too like living life in pain.',
  'rebel without a cause. or dark mode.',
  'are you testing my structural integrity?',
  'you must really love a blank canvas.',
  'it’s like a dentist’s office, but in an app.',
  'turning on the headlights, are we?',
  'warning: high contrast ahead.',
  'unlocked: flashbang mode.',
  'blinding. literally.',
  'light mode? why though?',
];
    document.getElementById('theme-toggle').addEventListener('click', () => {
      const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
      document.documentElement.setAttribute('data-theme', isDark ? 'light' : 'dark');
      localStorage.setItem('theme', isDark ? 'light' : 'dark');

      if (isDark) {
        const msg = LIGHT_MODE_QUIPS[Math.floor(Math.random() * LIGHT_MODE_QUIPS.length)];
        console.log('%c ' + msg + ' ', 'background:#7747CC;color:#fff;padding:2px 6px;');
      }
    });
  </script>

  <main>
    <slot />
  </main>

  <footer>
    <div class="footer-main">
      <span class="footer-copy">© {new Date().getFullYear()} Jordan Lowell</span>

      <div class="footer-icons">
        <a href="https://github.com/stderr-guru" aria-label="GitHub">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
            <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/>
          </svg>
        </a>
        <a href="https://www.linkedin.com/in/jordandlowell/" aria-label="LinkedIn">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
            <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/>
            <rect x="2" y="9" width="4" height="12"/>
            <circle cx="4" cy="4" r="2"/>
          </svg>
        </a>
        <a href="mailto:jordan@stderr.guru" aria-label="Email">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round">
            <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
            <polyline points="22,6 12,13 2,6"/>
          </svg>
        </a>
      </div>

      <span class="footer-tags">NC / Remote East Coast</span>
    </div>

    <div class="footer-meta">
      <p class="footer-a11y">
        This site aims to meet <a href="https://www.w3.org/WAI/WCAG21/quickref/" target="_blank" rel="noopener">WCAG 2.1 AA</a> accessibility standards.
        If you encounter a barrier, please <a href="mailto:jordan@stderr.guru">let me know</a>.
      </p>
      <p class="footer-colophon">
        Built with <a href="https://astro.build" target="_blank" rel="noopener">Astro</a> &amp; Cloudflare.
        Set in Playfair Display &amp; Inter.
        Source on <a href="https://github.com" target="_blank" rel="noopener">GitHub</a>.
      </p>
    </div>
  </footer>

</body>
</html>
