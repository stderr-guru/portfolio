---
import Layout from '../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('writing'))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());
---

<Layout title="Writing — Jordan Lowell" activeNav="writing">
  <style>
    .writing-page {
      padding: 3.5rem 2rem;
      max-width: 1200px;
      margin: 0 auto;
    }

    .section-header {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      margin-bottom: 0.75rem;
    }

    .section-title {
      font-family: 'Playfair Display', Georgia, serif;
      font-size: 1.75rem;
      font-weight: 700;
    }

    .section-count {
      font-size: var(--label-size);
      letter-spacing: var(--label-spacing);
      color: var(--text-muted);
    }

    .section-rule {
      border: none;
      border-top: 1px solid var(--border);
      margin: 0;
    }

    .post-list { list-style: none; }

    .post-item {
      display: grid;
      grid-template-columns: 8rem 1fr 2rem;
      gap: 0 2.5rem;
      padding: 2.75rem 0;
      border-bottom: 1px solid var(--border);
      align-items: start;
    }

    .post-meta {
      display: flex;
      flex-direction: column;
      gap: 0.2rem;
      padding-top: 0.15rem;
    }

    .post-date,
    .post-read-time {
      font-size: var(--label-size);
      letter-spacing: 0.02em;
      color: var(--text-muted);
    }

    .post-body {
      display: flex;
      flex-direction: column;
      gap: 0.5rem;
    }

    .post-category {
      font-size: var(--label-size);
      letter-spacing: var(--label-spacing);
      text-transform: uppercase;
      color: var(--purple);
      font-weight: 600;
    }

    .post-title {
      font-family: 'Playfair Display', Georgia, serif;
      font-size: 1.4rem;
      font-weight: 700;
      line-height: 1.25;
      text-decoration: none;
      color: var(--black);
      display: block;
    }

    .post-title.featured { color: var(--purple); }
    .post-title:hover { opacity: 0.7; }

    .post-excerpt {
      font-size: 0.925rem;
      line-height: 1.65;
      color: var(--text-body);
      max-width: 65ch;
      margin-top: 0.25rem;
    }

    .post-arrow {
      display: flex;
      align-items: flex-start;
      padding-top: 0.35rem;
      color: var(--purple);
      font-size: 1.1rem;
      text-decoration: none;
    }

    .post-arrow:hover { opacity: 0.6; }
  </style>

  <div class="writing-page">
    <div class="section-header">
      <h1 class="section-title">Writing</h1>
      <span class="section-count">{posts.length} posts</span>
    </div>
    <hr class="section-rule" />

    <ul class="post-list">
      {posts.map(p => (
        <li class="post-item">
          <div class="post-meta">
            <span class="post-date">{p.data.date}</span>
            <span class="post-read-time">{p.data.readTime}</span>
          </div>

          <div class="post-body">
            <span class="post-category">{p.data.category}</span>
            <a href={`/writing/${p.id}`} class={`post-title${p.data.featured ? ' featured' : ''}`}>
              {p.data.title}
            </a>
            <p class="post-excerpt">{p.data.excerpt}</p>
          </div>

          <a href={`/writing/${p.id}`} class="post-arrow" aria-label="Read post">↗</a>
        </li>
      ))}
    </ul>
  </div>
</Layout>
