---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contact — Jordan Lowell" activeNav="contact">
  <style>
    .contact-page {
      max-width: 1200px;
      margin: 0 auto;
      padding: 3.5rem 2rem;
    }

    /* ── HEADER ── */
    .page-header {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      margin-bottom: 0.75rem;
    }

    .page-title {
      font-family: 'Playfair Display', Georgia, serif;
      font-size: 1.75rem;
      font-weight: 700;
    }

    .page-subtitle {
      font-size: var(--label-size);
      letter-spacing: var(--label-spacing);
      color: var(--text-muted);
    }

    .page-rule {
      border: none;
      border-top: 1px solid var(--border);
      margin: 0 0 3rem;
    }

    /* ── TWO-COL ── */
    .contact-grid {
      display: grid;
      grid-template-columns: 1fr 400px;
      gap: 4rem;
      align-items: start;
    }

    /* ── SIDEBAR ── */
    .sidebar {
      display: flex;
      flex-direction: column;
      gap: 0;
      border: 1px solid var(--border);
    }

    .info-block {
      padding: 1.25rem 1.5rem;
      border-bottom: 1px solid var(--border);
    }

    .info-block:last-child { border-bottom: none; }

    .info-label {
      font-size: var(--label-size);
      letter-spacing: var(--label-spacing);
      text-transform: uppercase;
      color: var(--purple);
      font-weight: 600;
      margin-bottom: 0.85rem;
    }

    .info-link {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      font-size: 0.9rem;
      color: var(--black);
      text-decoration: none;
      margin-bottom: 0.5rem;
    }

    .info-link:last-child { margin-bottom: 0; }
    .info-link:hover { opacity: 0.6; }

    .info-text {
      font-family: 'Courier New', monospace;
      font-size: 0.8rem;
      line-height: 1.7;
      color: var(--text-body);
    }

    .note-box {
      margin-top: 1rem;
      border: 1px dashed var(--border);
      padding: 1.25rem 1.5rem;
    }

    .note-text {
      font-family: 'Courier New', monospace;
      font-size: 0.8rem;
      line-height: 1.7;
      color: var(--text-muted);
    }

    .note-text strong {
      color: var(--purple);
      font-weight: 600;
    }

    @media (max-width: 640px) {
      .contact-page {
        padding: 2rem 1.25rem;
      }

      .page-header {
        flex-direction: column;
        align-items: flex-start;
        gap: 0.25rem;
      }

      .contact-grid {
        grid-template-columns: 1fr;
        gap: 2.5rem;
      }
    }
  </style>

  <div class="contact-page">
    <div class="page-header">
      <h1 class="page-title">Get in touch</h1>
      <span class="page-subtitle">response within 48h</span>
    </div>
    <hr class="page-rule" />

    <div class="contact-grid">

      <!-- FORM -->
      <div>
        <iframe
          data-tally-src="https://tally.so/embed/2ERlOe?alignLeft=1&hideTitle=1&transparentBackground=1&dynamicHeight=1"
          loading="lazy"
          width="100%"
          height="300"
          frameborder="0"
          marginheight="0"
          marginwidth="0"
          title="Get in touch"
        ></iframe>
        <script>var d=document,w="https://tally.so/widgets/embed.js",v=function(){"undefined"!=typeof Tally?Tally.loadEmbeds():d.querySelectorAll("iframe[data-tally-src]:not([src])").forEach((function(e){e.src=e.dataset.tallySrc}))};if("undefined"!=typeof Tally)v();else if(d.querySelector('script[src="'+w+'"]')==null){var s=d.createElement("script");s.src=w,s.onload=v,s.onerror=v,d.body.appendChild(s);}</script>
      </div>

      <!-- SIDEBAR -->
      <div>
        <div class="sidebar">
          <div class="info-block">
            <div class="info-label">Direct</div>
            <a href="mailto:jordanl@xternsoftware.com" class="info-link">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
              jordanl@xternsoftware.com
            </a>
          </div>

          <div class="info-block">
            <div class="info-label">Elsewhere</div>
            <a href="https://github.com" class="info-link">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/></svg>
              github.com/jordanlowell
            </a>
            <a href="https://linkedin.com" class="info-link">
              <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/></svg>
              linkedin.com/in/jordanlowell
            </a>
          </div>

          <div class="info-block">
            <div class="info-label">Availability</div>
            <p class="info-text">Open to consulting, contract, and staff-level roles. Based in Berlin (CET). Happy to work async across time zones.</p>
          </div>
        </div>

        <div class="note-box">
          <p class="note-text"><strong>Note:</strong> I respond to all messages personally. If you don't hear back within 48h, check your spam folder.</p>
        </div>
      </div>

    </div>
  </div>
</Layout>
