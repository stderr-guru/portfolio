---
import Layout from '../layouts/Layout.astro';
import PlaygroundTerminal from '../components/PlaygroundTerminal.svelte';
import { getCollection } from 'astro:content';
import type { ProjectEntry, PostEntry } from '../lib/commands';

const projects: ProjectEntry[] = (await getCollection('work'))
  .filter(p => !p.id.startsWith('_'))
  .sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99))
  .map(p => ({
    id: p.id,
    title: p.data.title,
    category: p.data.category,
    year: p.data.year,
    description: p.data.description,
    tags: p.data.tags,
    body: p.body ?? '',
  }));

const posts: PostEntry[] = (await getCollection('writing'))
  .filter(p => !p.id.startsWith('_'))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime())
  .map(p => ({
    id: p.id,
    title: p.data.title,
    category: p.data.category,
    date: p.data.date,
    readTime: p.data.readTime,
    excerpt: p.data.excerpt,
    body: p.body ?? '',
  }));
---

<Layout title="Playground — Jordan Lowell" activeNav="playground">
  <style>
    .playground-page {
      display: flex;
      flex-direction: column;
      flex: 1;
    }

    .playground-header {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      padding: 1rem 2rem 0.75rem;
      border-bottom: 1px solid var(--border);
      flex-shrink: 0;
    }

    .playground-title {
      font-family: 'Playfair Display', Georgia, serif;
      font-size: 1.1rem;
      font-weight: 700;
    }

    .playground-hint {
      font-size: var(--label-size);
      letter-spacing: var(--label-spacing);
      color: var(--text-muted);
    }

    .terminal-wrap {
      flex: 1;
      min-height: 0;
      overflow: hidden;
      display: flex;
      flex-direction: column;
    }

    .terminal-wrap :global(astro-island) {
      flex: 1;
      min-height: 0;
      display: flex;
      flex-direction: column;
    }
  </style>

  <div class="playground-page">
    <div class="playground-header">
      <span class="playground-title">Terminal</span>
      <span class="playground-hint">type help to get started</span>
    </div>
    <div class="terminal-wrap">
      <PlaygroundTerminal client:only="svelte" projects={projects} posts={posts} />
    </div>
  </div>
</Layout>
